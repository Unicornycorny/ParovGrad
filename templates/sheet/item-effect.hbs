<section class="pg-sheet">
  <div class="sheet-body">
    <header class="pg-sheet-header">
      <h1>{{document.name}}</h1>
      <div class="pg-item-sheet-mode">
        {{#if isEditMode}}
          Режим: редактирование
        {{else}}
          Режим: просмотр
        {{/if}}
      </div>
    </header>

    {{#if isEditMode}}
      <div class="pg-form-field">
        <label>Название</label>
        <input type="text" name="name" value="{{document.name}}" />
      </div>

      <div class="pg-form-grid pg-form-grid--two-columns">
        <div class="pg-form-field">
          <label>Уровень</label>
          <input type="number" name="system.level" min="0" step="1" value="{{system.level}}" />
        </div>

        <div class="pg-form-field">
          <label>Тип</label>
          <input type="text" name="system.effectType" value="{{system.effectType}}" />
        </div>
      </div>

      <div class="pg-form-field">
        <label>Воздействие эффекта</label>
        <textarea name="system.impact" rows="3">{{system.impact}}</textarea>
      </div>

      <div class="pg-form-field">
        <label>Снятие эффекта</label>
        <textarea name="system.removal" rows="3">{{system.removal}}</textarea>
      </div>

      <div class="pg-form-field">
        <label>Описание</label>
        <textarea name="system.description" rows="3">{{system.description}}</textarea>
      </div>

      <div class="pg-form-field">
        <label>Влияния эффекта</label>

        <div class="pg-effect-modifier-add-row">
          <select class="pg-effect-modifier-target">
            {{#each modifierTargetOptions}}
              <option value="{{this.value}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
            {{/each}}
          </select>

          <input type="number" class="pg-effect-modifier-value-input" step="1" value="0">
          <button type="button" class="pg-effect-modifier-add">+</button>
        </div>

        <p class="pg-form-hint">Положительное число усиливает показатель, отрицательное — уменьшает.</p>

        {{#if modifierList.length}}
          <div class="pg-effect-modifier-list">
            {{#each modifierList}}
              <div class="pg-effect-modifier-row" data-modifier-index="{{this.index}}">
                <div class="pg-effect-modifier-row__label">{{this.label}}</div>
                <input
                  type="number"
                  class="pg-effect-modifier-row__value"
                  data-modifier-index="{{this.index}}"
                  step="1"
                  value="{{this.value}}"
                >
                <button type="button" class="pg-effect-modifier-delete" data-modifier-index="{{this.index}}">Удалить</button>
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="pg-effect-modifier-empty">Влияния не добавлены</div>
        {{/if}}
      </div>
    {{else}}
      <div class="pg-weapon-stat-grid">
        <article class="pg-weapon-stat">
          <div class="pg-weapon-stat__label">Название</div>
          <div class="pg-weapon-stat__value">{{effectView.name}}</div>
        </article>

        <article class="pg-weapon-stat">
          <div class="pg-weapon-stat__label">Уровень</div>
          <div class="pg-weapon-stat__value">{{effectView.level}}</div>
        </article>

        <article class="pg-weapon-stat">
          <div class="pg-weapon-stat__label">Тип</div>
          <div class="pg-weapon-stat__value">{{effectView.effectType}}</div>
        </article>

        <article class="pg-weapon-stat pg-weapon-stat--full">
          <div class="pg-weapon-stat__label">Воздействие</div>
          <div class="pg-weapon-stat__value">{{effectView.impact}}</div>
        </article>

        <article class="pg-weapon-stat pg-weapon-stat--full">
          <div class="pg-weapon-stat__label">Снятие</div>
          <div class="pg-weapon-stat__value">{{effectView.removal}}</div>
        </article>

        <article class="pg-weapon-stat pg-weapon-stat--full">
          <div class="pg-weapon-stat__label">Описание</div>
          <div class="pg-weapon-stat__value">{{effectView.description}}</div>
        </article>

        <article class="pg-weapon-stat pg-weapon-stat--full">
          <div class="pg-weapon-stat__label">Влияния</div>
          <div class="pg-weapon-stat__value">
            {{#if effectView.modifierList.length}}
              <div class="pg-effect-modifier-readonly-list">
                {{#each effectView.modifierList}}
                  <div class="pg-effect-modifier-readonly-row">
                    <span>{{this.label}}</span>
                    <strong>{{this.signedValue}}</strong>
                  </div>
                {{/each}}
              </div>
            {{else}}
              —
            {{/if}}
          </div>
        </article>
      </div>
    {{/if}}
  </div>
</section>
