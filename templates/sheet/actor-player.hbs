<section class="pg-sheet">
  <div class="sheet-body">
    <h1>{{document.name}}</h1>

    <section>
      <h2>Характеристики</h2>

      <div>
        <label>Телосложение</label>
        <input type="number" name="system.stats.constitution" min="1" max="20" value="{{system.stats.constitution}}">
      </div>

      <div>
        <label>Внимание</label>
        <input type="number" name="system.stats.awareness" min="1" max="20" value="{{system.stats.awareness}}">
      </div>

      <div>
        <label>Движение</label>
        <input type="number" name="system.stats.movement" min="1" max="20" value="{{system.stats.movement}}">
      </div>

      <div>
        <label>Мышление</label>
        <input type="number" name="system.stats.thinking" min="1" max="20" value="{{system.stats.thinking}}">
      </div>

      <div>
        <label>Воля</label>
        <input type="number" name="system.stats.will" min="1" max="20" value="{{system.stats.will}}">
      </div>
    </section>

    <section>
      <h2>Показатели</h2>

      <div>
        <label>Вдохновение</label>
        <input type="number" name="system.inspiration" min="0" value="{{system.inspiration}}">
      </div>

      <div>
        <label>Опыт</label>
        <input type="number" name="system.experience" min="0" value="{{system.experience}}">
      </div>

      <div>
        <label>Уровень</label>
        <input type="number" name="system.level" min="0" value="{{system.level}}">
      </div>

      <div>
        <label>Здоровье</label>
        <input type="number" name="system.health.value" min="0" value="{{system.health.value}}">
        /
        <input type="number" name="system.health.max" min="0" value="{{system.health.max}}">
      </div>
    </section>

    <section>
      <h2>Предметы</h2>

      {{#if items.length}}
      <ul class="pg-item-list">
        {{#each items}}
        <li class="pg-item-row">
          <button type="button" class="pg-item-link" data-item-id="{{this.id}}">
            {{this.name}}
          </button>

          <button type="button" class="pg-item-delete" data-item-id="{{this.id}}" aria-label="Удалить предмет"
            title="Удалить предмет">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path
                d="M9 3h6l1 2h4v2H4V5h4l1-2zm1 6h2v8h-2V9zm4 0h2v8h-2V9zM7 9h2v8H7V9zm-1 12h12a2 2 0 0 0 2-2V7H4v12a2 2 0 0 0 2 2z" />
            </svg>
          </button>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p>Нет предметов</p>
      {{/if}}
    </section>
  </div>
</section>