<section class="pg-sheet">
  <div class="sheet-body">
    <h1>{{document.name}}</h1>

    <section>
      <h2>NPC</h2>
      <div>
        <label>Роль</label>
        <input type="text" name="system.role" value="{{system.role}}">
      </div>
    </section>

    <section>
      <h2>Характеристики</h2>

      {{#each statViews}}
      <div class="pg-stat-row">
        <label for="pg-stat-{{this.key}}">{{this.label}}</label>
        <div class="pg-stat-controls pg-stat-controls--with-influence">
          <input
            id="pg-stat-{{this.key}}"
            type="number"
            name="system.stats.{{this.key}}"
            min="1"
            max="20"
            value="{{this.value}}"
          >
          <input
            type="text"
            class="pg-stat-influence"
            value="{{this.influenceDisplay}}"
            readonly
            disabled
            tabindex="-1"
            title="{{this.influenceTooltip}}"
            aria-label="Сумма внешних влияний: {{this.influenceDisplay}}"
          >
        </div>
      </div>
      {{/each}}
    </section>

    <section>
      <h2>Показатели</h2>

      <div>
        <label>Вдохновение</label>
        <input type="number" name="system.inspiration" min="0" value="{{system.inspiration}}">
      </div>

      <div>
        <label>Опыт</label>
        <input type="number" name="system.experience" min="0" value="{{system.experience}}">
      </div>

      <div>
        <label>Уровень</label>
        <input type="number" name="system.level" min="0" value="{{system.level}}">
      </div>

      <div>
        <label>Внешнее влияние на макс. здоровье</label>
        <input
          type="text"
          class="pg-stat-influence"
          value="{{healthInfluenceView.influenceDisplay}}"
          readonly
          disabled
          tabindex="-1"
          title="{{healthInfluenceView.influenceTooltip}}"
        >
      </div>

      <div>
        <label>Здоровье</label>
        <input type="number" name="system.health.value" min="0" max="{{derivedHealthMax}}" value="{{system.health.value}}">
        /
        <input type="number" name="system.health.max" min="0" value="{{system.health.max}}">
      </div>
      <div>
        <label>Итоговое макс. здоровье</label>
        <input type="number" value="{{derivedHealthMax}}" disabled>
      </div>
    </section>

    <section>
      <div class="pg-section-header">
        <h2>Эффекты</h2>
        <button type="button" class="pg-effect-create">+ Добавить эффект</button>
      </div>

      <p class="pg-form-hint">Можно добавить эффект кнопкой или перетащить на лист/токен шаблон эффекта либо уже существующий активный эффект.</p>

      {{#if effects.length}}
      <ul class="pg-effect-list">
        {{#each effects}}
        <li class="pg-effect-row {{#if this.disabled}}is-disabled{{/if}}" data-effect-id="{{this.id}}" draggable="true">
          <img class="pg-effect-row__icon" src="{{this.img}}" alt="{{this.name}}">

          <div class="pg-effect-row__content">
            <div class="pg-effect-row__title-line">
              <button type="button" class="pg-effect-edit pg-effect-row__name" data-effect-id="{{this.id}}">{{this.name}}</button>
              {{#if this.disabled}}<span class="pg-effect-badge">Выключен</span>{{/if}}
            </div>

            <div class="pg-effect-row__meta">
              <span>Уровень: {{this.level}}</span>
              <span>Тип: {{#if this.effectType}}{{this.effectType}}{{else}}—{{/if}}</span>
              <span>Изменений: {{this.changesCount}}</span>
            </div>

            {{#if this.impact}}
            <div class="pg-effect-row__text"><strong>Воздействие:</strong> {{this.impact}}</div>
            {{/if}}

            {{#if this.removal}}
            <div class="pg-effect-row__text"><strong>Снятие:</strong> {{this.removal}}</div>
            {{/if}}

            {{#if this.modifierSummary}}
            <div class="pg-effect-row__text"><strong>Влияния:</strong> {{this.modifierSummary}}</div>
            {{/if}}

            {{#if this.sourceLabel}}
            <div class="pg-effect-row__source">Шаблон: {{this.sourceLabel}}</div>
            {{/if}}
          </div>

          <div class="pg-effect-row__actions">
            <button type="button" class="pg-effect-toggle" data-effect-id="{{this.id}}">{{#if this.disabled}}Включить{{else}}Выключить{{/if}}</button>
            <button type="button" class="pg-effect-edit" data-effect-id="{{this.id}}">Изменить</button>
            <button type="button" class="pg-effect-delete" data-effect-id="{{this.id}}">Удалить</button>
          </div>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p>Нет активных эффектов</p>
      {{/if}}
    </section>

    <section>
      <h2>Предметы</h2>

      {{#if items.length}}
      <ul class="pg-item-list">
        {{#each items}}
        <li class="pg-item-row">
          <button type="button" class="pg-item-link" data-item-id="{{this.id}}">
            {{this.name}}
          </button>

          <button type="button" class="pg-item-delete" data-item-id="{{this.id}}" aria-label="Удалить предмет"
            title="Удалить предмет">
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true">
              <path
                d="M9 3h6l1 2h4v2H4V5h4l1-2zm1 6h2v8h-2V9zm4 0h2v8h-2V9zM7 9h2v8H7V9zm-1 12h12a2 2 0 0 0 2-2V7H4v12a2 2 0 0 0 2 2z" />
            </svg>
          </button>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p>Нет предметов</p>
      {{/if}}
    </section>
  </div>
</section>
